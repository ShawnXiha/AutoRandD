# 食品与生工领域多智能体研发系统配置文件
# Food & Bioengineering R&D Multi-Agent System Configuration

# Ollama 配置
OLLAMA_MODEL=qwen3.5:cloud
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=4000

# 搜索 API 配置 (可选)
# Tavily API (用于高质量搜索)
TAVILY_API_KEY=your_tavily_api_key_here

# DuckDuckGo (免费搜索)
# 无需配置，直接使用

# Serper API (Google搜索)
SERPER_API_KEY=your_serper_api_key_here

# Google Patents API (专利搜索)
GOOGLE_PATENTS_API_KEY=your_google_patents_api_key_here

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 数据存储目录
DATA_DIR=data
OUTPUT_DIR=outputs

# 系统配置
DEBUG=False
SHOW_PROGRESS=True
